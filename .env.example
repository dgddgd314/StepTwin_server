APP_NAME="Steptwin API"
APP_ENV="local"
APP_VERSION="0.1.0"
LOG_LEVEL="INFO"
API_V1_PREFIX="/api/v1"
CORS_ORIGINS='["http://localhost:3000", "http://localhost:5173"]'

# Leave empty to run the API without database-backed routing.
DATABASE_URL="postgresql+asyncpg://app:app@127.0.0.1:5432/steptwin"
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE_SECONDS=1800
PEDESTRIAN_GRAPH_VERTEX_TABLE="osm_pedestrian_vertices"
PEDESTRIAN_GRAPH_EDGE_TABLE="osm_pedestrian_edges"
PEDESTRIAN_GRAPH_MAX_SNAP_DISTANCE_METERS=500

# TMAP API. Keep the real key in local .env only.
TMAP_APP_KEY=""
TMAP_BASE_URL="https://apis.openapi.sk.com"
TMAP_TRANSIT_PATH="/transit/routes"
TMAP_TIMEOUT_SECONDS=5
TMAP_USE_LIVE=false
TMAP_LANG=0
TMAP_FORMAT="json"
TMAP_COUNT=10
TMAP_SEARCH_DTTM=""
